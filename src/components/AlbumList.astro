---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Photo {
  src: ImageMetadata;
  alt: string;
  caption: string;
  size: 'small' | 'medium' | 'large' | 'full';
  orientation?: 'portrait' | 'landscape' | 'square';
  exif?: Record<string, string | number>;
}
interface Props {
  photos: Photo[];
}
const { photos } = Astro.props;

const rendered = await Promise.all(
  photos.map(async (p) => {
    const big = await getImage({ src: p.src, width: 2000, format: 'webp' });
    const ar = p.src.width && p.src.height ? +(p.src.width / p.src.height).toFixed(4) : 1;
    const orientation = p.orientation ?? (ar > 1.05 ? 'landscape' : ar < 0.95 ? 'portrait' : 'square');
    return { p, full: big.src, ar, orientation };
  }),
);
---

<div class="album">
  {rendered.map(({ p, full, ar, orientation }, i) => (
    <figure class:list={['shot', `is-${orientation}`, `s-${p.size}`]}>
      <button
        class="shot__btn"
        data-lb
        data-full={full}
        data-alt={p.alt || p.caption}
        data-caption={p.caption}
        data-exif={JSON.stringify(p.exif ?? {})}
        aria-label={p.caption || `Photograph ${i + 1}`}
        style={`--ar:${ar}`}
      >
        <Image src={p.src} alt={p.alt || p.caption} widths={[480, 768, 1100, 1600]} sizes="(max-width: 900px) 92vw, 900px" />
      </button>
      <figcaption class="shot__cap">
        <span class="shot__num label">{String(i + 1).padStart(2, '0')}</span>
        {p.caption && <span class="shot__text">{p.caption}</span>}
      </figcaption>
    </figure>
  ))}
</div>

<style>
  .album {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(2.5rem, 1.5rem + 5vw, 6rem);
    padding-block: clamp(1rem, 3vw, 3rem);
  }
  .shot {
    width: 100%;
    max-width: 940px;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .shot.is-portrait { max-width: 660px; }
  /* Small photos sit narrower and offset for editorial rhythm. */
  .shot.s-small { max-width: 520px; align-self: flex-start; margin-inline-start: clamp(0, 4vw, 8%); }
  .shot.s-full { max-width: 1300px; }

  .shot__btn {
    display: block;
    width: 100%;
    overflow: hidden;
    aspect-ratio: var(--ar);
    background: var(--paper-2);
  }
  .shot__btn :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s var(--ease), filter 0.6s var(--ease);
  }
  .shot__btn:hover :global(img) { transform: scale(1.025); }

  .shot__cap {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    color: var(--ink-soft);
  }
  .shot__text { font-family: var(--font-display); font-style: italic; font-size: var(--step-1); }

  @media (max-width: 700px) {
    .shot.s-small { margin-inline-start: 0; align-self: stretch; }
  }
</style>
