---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer__inner">
    <p class="footer__mark">
      <span class="footer__name">{site.name}</span>
      <span class="label">© {year}</span>
    </p>
    <ul class="footer__socials">
      {site.socials.map((s) => (
        <li>
          <a class="link-underline" href={s.href} rel="me noopener" target={s.href.startsWith('http') ? '_blank' : undefined}>
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</footer>

<style>
  .footer {
    margin-top: clamp(4rem, 2rem + 8vw, 9rem);
    border-top: 1px solid var(--line);
    padding-block: clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.2rem 2rem;
    align-items: baseline;
    justify-content: space-between;
  }
  .footer__mark { display: flex; align-items: baseline; gap: 0.8rem; }
  .footer__name { font-family: var(--font-display); font-size: var(--step-1); }
  .footer__socials { list-style: none; display: flex; gap: 1.6rem; padding: 0; }
  .footer__socials a { font-size: var(--step--1); letter-spacing: 0.04em; text-transform: uppercase; }
</style>
