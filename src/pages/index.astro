---
import BaseLayout from '../layouts/BaseLayout.astro';
import FeedMasonry from '../components/FeedMasonry.astro';
import Lightbox from '../components/Lightbox.astro';
import { getFeed } from '../lib/feed';
import { site } from '../data/site';

const items = await getFeed();
---

<BaseLayout>
  <section class="hero wrap">
    <p class="label hero__eyebrow rise">Selected work — {site.location}</p>
    <h1 class="hero__title rise" style="animation-delay:80ms">{site.tagline}</h1>
  </section>

  <section class="wrap">
    {items.length > 0 ? (
      <FeedMasonry items={items} />
    ) : (
      <div class="empty">
        <p class="empty__title">The wall is empty — for now.</p>
        <p>
          Add your first album with
          <code>npm run photos:new-album -- --title "…" --dir ./import/…</code>
          or a single photo with <code>npm run photos:add-single</code>.
        </p>
      </div>
    )}
  </section>

  <Lightbox />
</BaseLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 2rem + 8vw, 8rem) clamp(2.2rem, 1.5rem + 4vw, 4.5rem);
  }
  .hero__eyebrow { display: block; margin-bottom: 1.4rem; }
  .hero__title {
    font-size: var(--step-3);
    max-width: 16ch;
    font-weight: 420;
    text-wrap: balance;
  }
  .empty {
    border: 1px dashed var(--line);
    padding: clamp(2rem, 5vw, 4rem);
    text-align: center;
    color: var(--ink-soft);
    max-width: 62ch;
    margin-inline: auto;
  }
  .empty__title { font-family: var(--font-display); font-size: var(--step-2); color: var(--ink); margin-bottom: 0.8rem; }
  .empty code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background: var(--paper-2);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    display: inline-block;
    margin: 0.2rem 0.1rem;
  }
</style>
